# ===================
# 敏感数据 - 绝对不能提交
# ===================
vault.json
auth.json
*.vault

# ===================
# 打包输出 - 不应提交
# ===================
release/

# ===================
# 依赖和构建 - 不应提交
# ===================
node_modules/
dist/
build/

# ===================
# 开发环境配置
# ===================
.env
.env.local
.env.*.local

# ===================
# IDE 和操作系统文件
# ===================
.idea/
.vscode/
*.swp
*.swo
.DS_Store
Thumbs.db

# ===================
# 日志和临时文件
# ===================
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ===================
# 测试和缓存
# ===================
coverage/
.cache/
